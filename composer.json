{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "amidesfahani/filament-tinyeditor": "^3.0",
        "awcodes/filament-table-repeater": "3.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "bezhansalleh/filament-shield": "^3.3",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "blade-ui-kit/blade-icons": "^1.8",
        "filament/filament": "^3.3",
        "filament/spatie-laravel-media-library-plugin": "^3.3",
        "filament/spatie-laravel-translatable-plugin": "^3.2",
        "flowframe/laravel-trend": "^0.4.0",
        "gavan4eg/cashalotapi": "*",
        "guzzlehttp/guzzle": "^7.10",
        "kahusoftware/filament-ckeditor-field": "^1.0",
        "kerigard/laravel-lang-ru": "^2.0",
        "laravel/framework": "^12.0",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.10.1",
        "liqpay/liqpay": "^1.4",
        "mledoze/countries": "^5.1",
        "phpoffice/phpspreadsheet": "^2.1",
        "socialiteproviders/apple": "^5.7",
        "solution-forest/filament-translate-field": "^1.4",
        "solution-forest/filament-tree": "^2.1",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-permission": "^6.21",
        "spatie/laravel-sitemap": "^7.3",
        "symfony/dom-crawler": "^7.0",
        "twig/twig": "^3.10",
        "wiebenieuwenhuis/filament-code-editor": "^1.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.23",
        "laravel-lang/lang": "^15.22",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers_static_pages.php",
            "app/Support/helpers_text.php",
            "app/Support/site_text.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.30"
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "packages/cashalotapi",
            "options": {
                "symlink": false
            }
        }
    ]
}
