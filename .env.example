APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
KIOSK_API_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

BINOTEL_WEBHOOK_PUBLIC_URL=
BINOTEL_CRM_BASE_URL=
BINOTEL_WEBHOOK_SECRET=
BINOTEL_IP_CHECK_MODE=strict

CALLCENTER_PIROGOVAYA_ENABLED=false
CALLCENTER_PIROGOVAYA_NAME=Pirogovaya
CALLCENTER_PIROGOVAYA_SLUG=pirogovaya
CALLCENTER_PIROGOVAYA_BASE_URL=http://pirogovaya.test
CALLCENTER_PIROGOVAYA_API_KEY=
CALLCENTER_PIROGOVAYA_ORDERS_ENDPOINT=/api/get-last-orders

CALLCENTER_PIE_ENABLED=false
CALLCENTER_PIE_NAME=Pie
CALLCENTER_PIE_SLUG=pie
CALLCENTER_PIE_BASE_URL=http://pie.test
CALLCENTER_PIE_API_KEY=
CALLCENTER_PIE_ORDERS_ENDPOINT=/api/get-last-orders

CASHALOT_ENABLED=false
CASHALOT_NUMFISCAL=
CASHALOT_CERTIFICATE=
CASHALOT_KEY=
CASHALOT_PASSWORD=
CASHALOT_API_URL=https://fsapi.cashalot.org.ua/
CASHALOT_TIMEOUT=20
CASHALOT_USE_SMART_ID=false
CASHALOT_KEY_PIN=
CASHALOT_AUTO_OPEN_SHIFT=true
CASHALOT_GET_QR_CODE=true
CASHALOT_QR_SIZE=512
CASHALOT_VISUALIZATION=true
CASHALOT_VIS_AS_HTML=false
CASHALOT_SEND_TO_CONSUMER=true
CASHALOT_CONSUMER_SERVICE_TYPE=0
PRINTSERVICE_VERIFY_TLS=true
